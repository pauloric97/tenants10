---
import type { Translations } from '../i18n/utils';
interface Props { t: Translations; }
const { t } = Astro.props;
const base = import.meta.env.BASE_URL;
const f = t.footer;
---

<footer class="bg-bg-light border-t border-blue-100">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10 mb-12">
      <!-- Brand -->
      <div class="sm:col-span-2 lg:col-span-1">
        <div class="flex items-center gap-2 mb-4">
          <img src={`${base}logo-icon.png`} alt="Tenants10" class="h-8 w-8" />
          <img src={`${base}logo-text.png`} alt="Tenants10" class="h-5" />
        </div>
        <p class="text-sm text-text-muted leading-relaxed max-w-xs">{f.tagline}</p>
        <!-- Social links -->
        <div class="flex gap-3 mt-5">
          <!-- LinkedIn -->
          <a
            href="#"
            aria-label="LinkedIn"
            class="w-8 h-8 rounded-full border border-gray-200 flex items-center justify-center text-gray-500 hover:text-primary hover:border-primary transition-colors"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z"/>
              <circle cx="4" cy="4" r="2"/>
            </svg>
          </a>
          <!-- Instagram -->
          <a
            href="#"
            aria-label="Instagram"
            class="w-8 h-8 rounded-full border border-gray-200 flex items-center justify-center text-gray-500 hover:text-primary hover:border-primary transition-colors"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <circle cx="12" cy="12" r="4"/>
              <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor"/>
            </svg>
          </a>
          <!-- Twitter/X -->
          <a
            href="#"
            aria-label="Twitter"
            class="w-8 h-8 rounded-full border border-gray-200 flex items-center justify-center text-gray-500 hover:text-primary hover:border-primary transition-colors"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Product -->
      <div>
        <h4 class="text-xs font-bold uppercase tracking-widest text-primary mb-4">{f.product.title}</h4>
        <ul class="space-y-3">
          {f.product.links.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-text-muted hover:text-primary transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h4 class="text-xs font-bold uppercase tracking-widest text-primary mb-4">{f.company.title}</h4>
        <ul class="space-y-3">
          {f.company.links.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-text-muted hover:text-primary transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h4 class="text-xs font-bold uppercase tracking-widest text-primary mb-4">{f.legal.title}</h4>
        <ul class="space-y-3">
          {f.legal.links.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-text-muted hover:text-primary transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-blue-100 pt-6 flex flex-col sm:flex-row justify-between items-center gap-2">
      <p class="text-xs text-text-muted">{f.copyright}</p>
      <p class="text-xs text-text-muted">{f.madeBy}</p>
    </div>
  </div>
</footer>
