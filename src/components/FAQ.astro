---
import type { Translations } from '../i18n/utils';
interface Props { t: Translations; }
const { t } = Astro.props;
---

<section id="faq" class="py-20 bg-white">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Big rounded card -->
    <div class="bg-bg-light rounded-3xl px-8 py-12 lg:px-16 lg:py-14">

      <!-- Header -->
      <div class="text-center mb-10">
        <p class="text-xs font-bold uppercase tracking-widest text-accent mb-4">{t.faq.label}</p>
        <h2 class="font-normal text-secondary leading-tight" style="font-size: clamp(40px, 5vw, 56px);">
          <strong class="font-extrabold text-primary">{t.faq.title1}</strong> {t.faq.title2}
        </h2>
      </div>

      <!-- FAQ items — divider style, no individual cards -->
      <div class="divide-y divide-blue-100">
        {t.faq.items.map((item) => (
          <details class="group py-1" name="faq">
            <summary class="flex items-center justify-between gap-6 py-4 cursor-pointer list-none">
              <span class="text-sm font-semibold text-primary">{item.question}</span>
              <span class="shrink-0 text-gray-400 group-open:rotate-45 transition-transform duration-200 text-xl font-light leading-none select-none">
                +
              </span>
            </summary>
            <div class="pb-4 pr-8">
              <p class="text-sm text-text-muted leading-relaxed">{item.answer}</p>
            </div>
          </details>
        ))}
      </div>

    </div>
  </div>
</section>
