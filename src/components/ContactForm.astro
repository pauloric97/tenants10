---
import type { Translations } from '../i18n/utils';
interface Props { t: Translations; }
const { t } = Astro.props;

const f = t.getStarted.form;
---

<section id="get-started" class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-12">
      <p class="text-xs font-bold uppercase tracking-widest text-accent mb-3">{t.getStarted.label}</p>
      <h2 class="text-4xl sm:text-5xl font-normal text-secondary leading-tight">
        {t.getStarted.title1} <strong class="font-extrabold text-primary">{t.getStarted.title2}</strong>
      </h2>
      <p class="text-text-muted mt-4 max-w-lg mx-auto">{t.getStarted.subtitle}</p>
    </div>

    <!-- Form card -->
    <div class="max-w-lg mx-auto bg-white rounded-3xl border border-gray-100 shadow-xl p-8">
      <h3 class="text-2xl font-bold text-secondary mb-1">{f.title}</h3>
      <p class="text-sm text-text-muted mb-6">{f.subtitle}</p>

      <form
        id="contact-form"
        class="space-y-4"
        data-success-title={f.successTitle}
        data-success-message={f.successMessage}
      >
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1.5">{f.name}</label>
            <input
              type="text"
              name="name"
              placeholder={f.namePlaceholder}
              required
              class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all"
            />
          </div>
          <div>
            <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1.5">{f.email}</label>
            <input
              type="email"
              name="email"
              placeholder={f.emailPlaceholder}
              required
              class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all"
            />
          </div>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1.5">{f.role}</label>
            <select
              name="role"
              required
              class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all bg-white text-gray-500"
            >
              <option value="" disabled selected>{f.rolePlaceholder}</option>
              {f.roles.map((r) => <option value={r}>{r}</option>)}
            </select>
          </div>
          <div>
            <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1.5">{f.units}</label>
            <input
              type="text"
              name="units"
              placeholder={f.unitsPlaceholder}
              class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all"
            />
          </div>
        </div>

        <div>
          <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1.5">{f.challenge}</label>
          <textarea
            name="challenge"
            placeholder={f.challengePlaceholder}
            rows={3}
            class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all resize-none"
          ></textarea>
        </div>

        <button
          type="submit"
          class="w-full bg-primary text-white px-6 py-3.5 rounded-full font-semibold text-sm hover:bg-primary-dark transition-all hover:shadow-lg flex items-center justify-center gap-3"
        >
          <span>{f.submit}</span>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </button>

        <p class="text-xs text-text-muted text-center">{f.privacy}</p>
      </form>

      <!-- Success state (hidden by default) -->
      <div id="form-success" class="hidden text-center py-8">
        <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
          <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
          </svg>
        </div>
        <h4 id="success-title" class="text-xl font-bold text-secondary mb-2"></h4>
        <p id="success-message" class="text-text-muted text-sm"></p>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const successDiv = document.getElementById('form-success');
  const successTitle = document.getElementById('success-title');
  const successMessage = document.getElementById('success-message');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    btn.disabled = true;
    btn.style.opacity = '0.7';

    const formData = new FormData(form);
    const data = Object.fromEntries(formData.entries());

    try {
      // TODO: Replace YOUR_FORM_ID with your Formspree form ID
      // Sign up free at https://formspree.io and create a form
      const response = await fetch('https://formspree.io/f/YOUR_FORM_ID', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify(data),
      });

      if (response.ok) {
        form.classList.add('hidden');
        if (successDiv && successTitle && successMessage) {
          successDiv.classList.remove('hidden');
          successTitle.textContent = form.dataset.successTitle ?? '';
          successMessage.textContent = form.dataset.successMessage ?? '';
        }
      } else {
        throw new Error('Failed');
      }
    } catch {
      btn.disabled = false;
      btn.style.opacity = '1';
      alert('Something went wrong. Please try again.');
    }
  });
</script>
