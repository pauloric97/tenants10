---
import type { Translations } from '../i18n/utils';
interface Props { t: Translations; }
const { t } = Astro.props;
---

<section class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 -mt-10">
  <div class="bg-white rounded-2xl shadow-xl border border-gray-100 px-6 py-6">
    <p class="text-center text-xs font-semibold text-text-muted uppercase tracking-widest mb-5">
      {t.stats.label}
    </p>
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
      <!-- Stat 1 -->
      <div class="text-center lg:border-r border-gray-100 px-4 pb-4 lg:pb-0">
        <div class="text-3xl font-bold text-primary">{t.stats.languages.value}</div>
        <div class="text-xs font-medium text-text-dark mt-1">{t.stats.languages.label}</div>
        <div class="text-xs text-text-muted mt-0.5">{t.stats.languages.detail}</div>
      </div>
      <!-- Stat 2 -->
      <div class="text-center lg:border-r border-gray-100 px-4 pb-4 lg:pb-0">
        <div class="text-3xl font-bold text-primary">{t.stats.time.value}</div>
        <div class="text-xs font-medium text-text-dark mt-1">{t.stats.time.label}</div>
      </div>
      <!-- Stat 3 -->
      <div class="text-center lg:border-r border-gray-100 px-4">
        <div class="text-3xl font-bold text-primary">{t.stats.documents.value}</div>
        <div class="text-xs font-medium text-text-dark mt-1">{t.stats.documents.label}</div>
      </div>
      <!-- Stat 4 -->
      <div class="text-center px-4">
        <div class="text-3xl font-bold text-primary">{t.stats.access.value}</div>
        <div class="text-xs font-medium text-text-dark mt-1">{t.stats.access.label}</div>
      </div>
    </div>
  </div>
</section>
