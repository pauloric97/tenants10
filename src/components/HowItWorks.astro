---
import type { Translations } from '../i18n/utils';
interface Props { t: Translations; }
const { t } = Astro.props;
---

<section id="how-it-works" class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-14">
      <p class="text-xs font-bold uppercase tracking-widest text-accent mb-3">{t.howItWorks.label}</p>
      <h2 class="text-4xl sm:text-5xl font-normal text-secondary leading-tight">
        {t.howItWorks.title1} <strong class="font-extrabold text-primary">{t.howItWorks.title2}</strong>
      </h2>
      <p class="text-text-muted mt-4 max-w-xl mx-auto">{t.howItWorks.subtitle}</p>
    </div>

    <!-- Steps -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {t.howItWorks.steps.map((step) => (
        <div class="bg-bg-card rounded-2xl p-8 hover:shadow-md transition-shadow">
          <div class="text-5xl font-extrabold text-primary/30 mb-4 leading-none">{step.number}</div>
          <h3 class="text-xl font-bold text-secondary mb-3">{step.title}</h3>
          <p class="text-text-muted text-sm leading-relaxed">{step.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
