---
import type { Translations } from '../i18n/utils';
interface Props { t: Translations; }
const { t } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<section class="hero-section" style={`background-image: url('${base}/background.jpg')`}>
  <!-- Content -->
  <div class="hero-content-wrap">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="hero-content">

        <!-- Badge -->
        <div class="hero-badge">
          <svg class="w-4 h-4 text-accent shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
          </svg>
          <span class="text-xs font-semibold text-accent uppercase tracking-wide">{t.hero.badge}</span>
        </div>

        <!-- Headline -->
        <h1 class="hero-title">
          {t.hero.title1}<br />
          <strong class="font-extrabold text-primary">{t.hero.title2}</strong><br />
          <strong class="font-extrabold text-primary">{t.hero.title3}</strong>
        </h1>

        <!-- Subtitle -->
        <p class="hero-subtitle">{t.hero.subtitle}</p>

        <!-- CTAs -->
        <div class="hero-ctas">
          <a href="#get-started" class="btn-primary">{t.hero.ctaPrimary}</a>
          <a href="#how-it-works" class="btn-secondary">{t.hero.ctaSecondary}</a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* ── Section ── */
  .hero-section {
    position: relative;
    overflow: hidden;
    padding-top: 64px; /* navbar height */
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }

  /* ── Content ── */
  .hero-content-wrap {
    position: relative;
    z-index: 10;
  }

  .hero-content {
    max-width: 560px;
    padding-top: 80px;
    padding-bottom: 90px;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(255,255,255,0.85);
    backdrop-filter: blur(4px);
    border: 1px solid #DDEAF5;
    border-radius: 9999px;
    padding: 6px 16px;
    margin-bottom: 24px;
  }

  .hero-title {
    font-size: clamp(36px, 5vw, 60px);
    line-height: 1.1;
    font-weight: 400;
    color: #194261;
    margin-bottom: 20px;
  }

  .hero-subtitle {
    font-size: 1rem;
    color: #718096;
    line-height: 1.7;
    margin-bottom: 32px;
    max-width: 420px;
  }

  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .btn-primary {
    background: #0042A5;
    color: white;
    padding: 14px 28px;
    border-radius: 9999px;
    font-weight: 600;
    font-size: 0.875rem;
    text-decoration: none;
    transition: background 0.2s, box-shadow 0.2s;
  }
  .btn-primary:hover { background: #00318A; box-shadow: 0 4px 16px rgba(0,66,165,0.3); }

  .btn-secondary {
    background: rgba(255,255,255,0.7);
    color: #194261;
    padding: 14px 28px;
    border-radius: 9999px;
    font-weight: 600;
    font-size: 0.875rem;
    text-decoration: none;
    border: 2px solid rgba(25,66,97,0.3);
    transition: background 0.2s, border-color 0.2s;
  }
  .btn-secondary:hover { background: white; border-color: #194261; }

  /* ── Mobile ── */
  @media (max-width: 1023px) {
    .hero-content {
      padding-top: 60px;
      padding-bottom: 60px;
      max-width: 100%;
    }

    .hero-title { font-size: clamp(30px, 8vw, 44px); }

    .hero-subtitle { max-width: 100%; }

    .btn-primary, .btn-secondary { padding: 12px 24px; }
  }
</style>
