---
import type { Translations } from '../i18n/utils';
interface Props { t: Translations; }
const { t } = Astro.props;
---

<section
  class="relative pt-16 overflow-hidden"
  style="background: linear-gradient(180deg, #B8D2E8 0%, #CDDFF0 25%, #DCE9F5 50%, #ECF3FA 75%, #F5F8FC 100%); min-height: 680px;"
>
  <!-- Staircase bars — absolutely positioned, anchored to bottom-right -->
  <div
    class="absolute bottom-0 right-0 flex items-end pointer-events-none"
    style="gap: 10px; padding-right: 0; height: 100%;"
    aria-hidden="true"
  >
    <div style="width: 155px; height: 42%; background: #C2D8EC; border-radius: 8px 8px 0 0;"></div>
    <div style="width: 155px; height: 57%; background: #AECADF; border-radius: 8px 8px 0 0;"></div>
    <div style="width: 155px; height: 72%; background: #96B7D2; border-radius: 8px 8px 0 0;"></div>
    <div style="width: 155px; height: 86%; background: #7CA4C5; border-radius: 8px 8px 0 0;"></div>
    <!-- Last bar goes off-screen to the right -->
    <div style="width: 155px; height: 100%; background: #6090B8; border-radius: 8px 8px 0 0; margin-right: -30px;"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col lg:flex-row items-start lg:items-center" style="min-height: 600px; padding-top: 80px; padding-bottom: 80px;">

      <!-- Left: text content -->
      <div class="flex-1 max-w-xl">
        <!-- Badge -->
        <div class="inline-flex items-center gap-2 bg-white/80 backdrop-blur-sm border border-blue-100 rounded-full px-4 py-1.5 mb-7">
          <svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
          </svg>
          <span class="text-xs font-semibold text-accent uppercase tracking-wide">{t.hero.badge}</span>
        </div>

        <!-- Headline -->
        <h1
          class="font-normal text-secondary leading-tight mb-7"
          style="font-size: clamp(38px, 5vw, 60px); line-height: 1.1;"
        >
          {t.hero.title1}<br />
          <strong class="font-extrabold text-primary">{t.hero.title2}</strong><br />
          <strong class="font-extrabold text-primary">{t.hero.title3}</strong>
        </h1>

        <!-- Subtitle -->
        <p class="text-base text-text-muted leading-relaxed mb-9 max-w-sm lg:max-w-md">
          {t.hero.subtitle}
        </p>

        <!-- CTAs -->
        <div class="flex flex-wrap gap-3">
          <a
            href="#get-started"
            class="bg-primary text-white px-7 py-3.5 rounded-full font-semibold text-sm hover:bg-primary-dark transition-all hover:shadow-lg"
          >
            {t.hero.ctaPrimary}
          </a>
          <a
            href="#how-it-works"
            class="bg-white/70 border-2 border-secondary/40 text-secondary px-7 py-3.5 rounded-full font-semibold text-sm hover:bg-white hover:border-secondary transition-all"
          >
            {t.hero.ctaSecondary}
          </a>
        </div>
      </div>

      <!-- Spacer so bars are visible on right (bars are absolute) -->
      <div class="hidden lg:block flex-1"></div>
    </div>
  </div>
</section>
