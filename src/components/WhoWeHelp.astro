---
import type { Translations } from '../i18n/utils';
interface Props { t: Translations; }
const { t } = Astro.props;

const icons = {
  chat: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>`,
  wrench: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>`,
  calendar: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>`,
  document: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>`,
};

const tabIcons = ['chat', 'wrench', 'calendar', 'document'] as const;

const tabs = [
  { key: 'tenants', label: t.whoWeHelp.tabs.tenants, data: t.whoWeHelp.tenants },
  { key: 'owners', label: t.whoWeHelp.tabs.owners, data: t.whoWeHelp.owners },
  { key: 'propertyManagers', label: t.whoWeHelp.tabs.propertyManagers, data: t.whoWeHelp.propertyManagers },
];
---

<section id="who-we-help" class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="text-center mb-12">
      <p class="text-xs font-bold uppercase tracking-widest text-accent mb-3">{t.whoWeHelp.label}</p>
      <h2 class="text-4xl sm:text-5xl font-normal text-secondary leading-tight">
        {t.whoWeHelp.title1} <strong class="font-extrabold text-primary">{t.whoWeHelp.title2}</strong><br />
        {t.whoWeHelp.title3}
      </h2>
      <p class="text-text-muted mt-4 max-w-xl mx-auto">{t.whoWeHelp.subtitle}</p>
    </div>

    <!-- Tabs -->
    <div class="flex justify-center gap-2 mb-10" role="tablist">
      {tabs.map(({ key, label }, i) => (
        <button
          role="tab"
          data-tab={key}
          aria-selected={i === 0}
          class={`tab-btn px-5 py-2 rounded-full text-sm font-semibold border transition-all ${
            i === 0
              ? 'bg-accent text-white border-accent'
              : 'bg-white text-gray-600 border-gray-200 hover:border-accent hover:text-accent'
          }`}
        >
          {label}
        </button>
      ))}
    </div>

    <!-- Tab panels -->
    {tabs.map(({ key, data }, i) => (
      <div
        id={`tab-panel-${key}`}
        role="tabpanel"
        class={`tab-panel ${i !== 0 ? 'hidden' : ''}`}
      >
        <div class="bg-bg-light rounded-3xl p-8 lg:p-12">
          <div class="flex flex-col-reverse lg:flex-row gap-10 items-start">
            <!-- Left: text content -->
            <div class="flex-1 max-w-lg">
              <h3 class="text-2xl sm:text-3xl font-bold text-secondary mb-3">{data.title}</h3>
              <p class="text-text-muted mb-6 leading-relaxed">{data.subtitle}</p>
              <ul class="space-y-4">
                {data.features.map((f, fi) => (
                  <li class="flex items-start gap-3">
                    <span class="mt-0.5 text-primary shrink-0" set:html={icons[tabIcons[fi % 4]]} />
                    <span class="text-sm text-text-dark">
                      <strong>{f.title}</strong> — {f.description}
                    </span>
                  </li>
                ))}
              </ul>
              <a
                href="#get-started"
                class="inline-block mt-8 bg-accent text-white px-6 py-3 rounded-full font-semibold text-sm hover:bg-primary transition-all hover:shadow-lg"
              >
                {data.cta}
              </a>
            </div>
            <!-- Right: App mockup -->
            <div class="flex-1 flex justify-center lg:max-w-sm w-full">
              <div class="app-mockup" data-mockup={key}>

                {key === 'tenants' && (
                  <div class="mockup-screen">
                    <!-- Header -->
                    <div class="mockup-header">
                      <div class="mockup-avatar">M</div>
                      <div>
                        <div class="mockup-header-title">Building Chat</div>
                        <div class="mockup-header-sub">Management · Online</div>
                      </div>
                    </div>
                    <!-- Chat messages -->
                    <div class="mockup-chat">
                      <div class="mockup-msg mockup-msg-in anim-1">
                        <div class="mockup-bubble mockup-bubble-in">Your lease renewal documents are ready 📄</div>
                        <div class="mockup-time">09:12</div>
                      </div>
                      <div class="mockup-msg mockup-msg-out anim-2">
                        <div class="mockup-bubble mockup-bubble-out">Thanks! I also have a heating issue in unit 3B</div>
                        <div class="mockup-time">09:14</div>
                      </div>
                      <div class="mockup-msg mockup-msg-in anim-3">
                        <div class="mockup-bubble mockup-bubble-in">Ticket #48 created ✓ Assigned to maintenance team</div>
                        <div class="mockup-time">09:15</div>
                      </div>
                      <div class="mockup-msg mockup-msg-in anim-4">
                        <div class="mockup-status-chip">🔧 Maintenance · <span class="chip-yellow">In progress</span></div>
                      </div>
                    </div>
                    <!-- Bottom nav -->
                    <div class="mockup-nav">
                      <div class="mockup-nav-item mockup-nav-active">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
                        <span>Chat</span>
                      </div>
                      <div class="mockup-nav-item">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><circle cx="12" cy="12" r="3"/></svg>
                        <span>Requests</span>
                      </div>
                      <div class="mockup-nav-item">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                        <span>Book</span>
                      </div>
                      <div class="mockup-nav-item">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                        <span>Docs</span>
                      </div>
                    </div>
                  </div>
                )}

                {key === 'owners' && (
                  <div class="mockup-screen">
                    <div class="mockup-header">
                      <div style="font-size:18px;">📊</div>
                      <div>
                        <div class="mockup-header-title">Property Overview</div>
                        <div class="mockup-header-sub">Musterstrasse 12</div>
                      </div>
                    </div>
                    <div style="padding: 12px 14px; display:flex; gap:8px;">
                      <div class="mockup-stat-card anim-1">
                        <div class="mockup-stat-val" style="color:#ef4444;">3</div>
                        <div class="mockup-stat-label">Open</div>
                      </div>
                      <div class="mockup-stat-card anim-2">
                        <div class="mockup-stat-val" style="color:#22c55e;">12</div>
                        <div class="mockup-stat-label">Resolved</div>
                      </div>
                      <div class="mockup-stat-card anim-3">
                        <div class="mockup-stat-val" style="color:#3b82f6;">8</div>
                        <div class="mockup-stat-label">Tenants</div>
                      </div>
                    </div>
                    <div style="padding: 0 14px 8px; font-size:10px; font-weight:700; color:#9ca3af; text-transform:uppercase; letter-spacing:.05em;">Maintenance Requests</div>
                    <div class="mockup-list">
                      <div class="mockup-list-item anim-2">
                        <div class="mockup-dot" style="background:#ef4444;"></div>
                        <div class="mockup-list-content">
                          <div class="mockup-list-title">Heating issue · Unit 4B</div>
                          <div class="mockup-list-sub">Reported 2h ago</div>
                        </div>
                        <div class="mockup-badge" style="background:#fef2f2;color:#ef4444;">Pending</div>
                      </div>
                      <div class="mockup-list-item anim-3">
                        <div class="mockup-dot" style="background:#f59e0b;"></div>
                        <div class="mockup-list-content">
                          <div class="mockup-list-title">Door lock · Unit 2A</div>
                          <div class="mockup-list-sub">Assigned to technician</div>
                        </div>
                        <div class="mockup-badge" style="background:#fffbeb;color:#d97706;">In progress</div>
                      </div>
                      <div class="mockup-list-item anim-4">
                        <div class="mockup-dot" style="background:#22c55e;"></div>
                        <div class="mockup-list-content">
                          <div class="mockup-list-title">Painting · Unit 1C</div>
                          <div class="mockup-list-sub">Completed yesterday</div>
                        </div>
                        <div class="mockup-badge" style="background:#f0fdf4;color:#16a34a;">Done</div>
                      </div>
                    </div>
                  </div>
                )}

                {key === 'propertyManagers' && (
                  <div class="mockup-screen">
                    <div class="mockup-header">
                      <div style="font-size:18px;">🏢</div>
                      <div>
                        <div class="mockup-header-title">Dashboard</div>
                        <div class="mockup-header-sub">3 buildings · 26 units</div>
                      </div>
                    </div>
                    <div style="padding: 8px 14px 4px; font-size:10px; font-weight:700; color:#9ca3af; text-transform:uppercase; letter-spacing:.05em;">My Buildings</div>
                    <div class="mockup-list">
                      <div class="mockup-building-card anim-1">
                        <div class="mockup-building-top">
                          <span class="mockup-building-name">Musterstrasse 12</span>
                          <span class="mockup-badge" style="background:#fef2f2;color:#ef4444;">2 open</span>
                        </div>
                        <div class="mockup-building-meta">8 units · Zurich</div>
                        <div class="mockup-progress-bar"><div style="width:65%;background:#3b82f6;border-radius:4px;height:100%;"></div></div>
                      </div>
                      <div class="mockup-building-card anim-2">
                        <div class="mockup-building-top">
                          <span class="mockup-building-name">Bahnhofstrasse 5</span>
                          <span class="mockup-badge" style="background:#f0fdf4;color:#16a34a;">All clear</span>
                        </div>
                        <div class="mockup-building-meta">12 units · Basel</div>
                        <div class="mockup-progress-bar"><div style="width:90%;background:#22c55e;border-radius:4px;height:100%;"></div></div>
                      </div>
                      <div class="mockup-building-card anim-3">
                        <div class="mockup-building-top">
                          <span class="mockup-building-name">Seeweg 3</span>
                          <span class="mockup-badge" style="background:#fffbeb;color:#d97706;">1 open</span>
                        </div>
                        <div class="mockup-building-meta">6 units · Geneva</div>
                        <div class="mockup-progress-bar"><div style="width:80%;background:#f59e0b;border-radius:4px;height:100%;"></div></div>
                      </div>
                    </div>
                  </div>
                )}

              </div>
            </div>
          </div>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .app-mockup {
    width: 260px;
    background: #fff;
    border-radius: 28px;
    border: 1px solid #e5e7eb;
    box-shadow: 0 20px 60px rgba(0,0,0,0.12), 0 4px 16px rgba(0,0,0,0.06);
    overflow: hidden;
    position: relative;
  }
  .app-mockup::before {
    content: '';
    display: block;
    width: 60px;
    height: 5px;
    background: #e5e7eb;
    border-radius: 3px;
    margin: 10px auto 0;
  }
  .mockup-screen {
    display: flex;
    flex-direction: column;
    min-height: 380px;
    padding-bottom: 8px;
  }
  .mockup-header {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 14px 14px 10px;
    border-bottom: 1px solid #f3f4f6;
  }
  .mockup-avatar {
    width: 32px; height: 32px;
    border-radius: 50%;
    background: #1e3a8a;
    color: white;
    font-size: 13px;
    font-weight: 700;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .mockup-header-title { font-size: 13px; font-weight: 700; color: #111827; }
  .mockup-header-sub { font-size: 10px; color: #6b7280; }
  .mockup-chat { flex: 1; padding: 12px 14px; display: flex; flex-direction: column; gap: 8px; }
  .mockup-msg { display: flex; flex-direction: column; gap: 2px; }
  .mockup-msg-in { align-items: flex-start; }
  .mockup-msg-out { align-items: flex-end; }
  .mockup-bubble {
    max-width: 190px;
    padding: 7px 11px;
    border-radius: 14px;
    font-size: 11px;
    line-height: 1.45;
  }
  .mockup-bubble-in { background: #f3f4f6; color: #111827; border-bottom-left-radius: 4px; }
  .mockup-bubble-out { background: #1e3a8a; color: #fff; border-bottom-right-radius: 4px; }
  .mockup-time { font-size: 9px; color: #9ca3af; padding: 0 4px; }
  .mockup-status-chip {
    font-size: 10px;
    background: #eff6ff;
    color: #1d4ed8;
    border-radius: 20px;
    padding: 4px 10px;
    border: 1px solid #bfdbfe;
  }
  .chip-yellow { color: #d97706; font-weight: 600; }
  .mockup-nav {
    display: flex;
    border-top: 1px solid #f3f4f6;
    padding: 6px 0 2px;
  }
  .mockup-nav-item {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
    font-size: 9px;
    color: #9ca3af;
    cursor: pointer;
    padding: 2px 0;
  }
  .mockup-nav-item svg { width: 16px; height: 16px; }
  .mockup-nav-active { color: #1e3a8a; }
  .mockup-stat-card {
    flex: 1;
    background: #f9fafb;
    border-radius: 10px;
    padding: 8px 6px;
    text-align: center;
    border: 1px solid #f3f4f6;
  }
  .mockup-stat-val { font-size: 20px; font-weight: 800; line-height: 1; }
  .mockup-stat-label { font-size: 9px; color: #6b7280; margin-top: 2px; }
  .mockup-list { display: flex; flex-direction: column; gap: 2px; padding: 0 10px; }
  .mockup-list-item {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 6px;
    border-radius: 10px;
    background: #f9fafb;
  }
  .mockup-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
  .mockup-list-content { flex: 1; min-width: 0; }
  .mockup-list-title { font-size: 11px; font-weight: 600; color: #111827; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .mockup-list-sub { font-size: 9px; color: #9ca3af; }
  .mockup-badge { font-size: 9px; font-weight: 600; padding: 2px 7px; border-radius: 20px; white-space: nowrap; flex-shrink: 0; }
  .mockup-building-card {
    background: #f9fafb;
    border-radius: 10px;
    padding: 9px 10px;
    border: 1px solid #f3f4f6;
    margin-bottom: 2px;
  }
  .mockup-building-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 2px; }
  .mockup-building-name { font-size: 11px; font-weight: 700; color: #111827; }
  .mockup-building-meta { font-size: 9px; color: #9ca3af; margin-bottom: 6px; }
  .mockup-progress-bar { height: 4px; background: #e5e7eb; border-radius: 4px; overflow: hidden; }

  /* entrance animations */
  @keyframes fadeSlideUp {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .anim-1 { animation: fadeSlideUp .35s ease both; }
  .anim-2 { animation: fadeSlideUp .35s .1s ease both; }
  .anim-3 { animation: fadeSlideUp .35s .2s ease both; }
  .anim-4 { animation: fadeSlideUp .35s .3s ease both; }

  /* re-trigger animation on tab switch */
  .app-mockup.replay .anim-1,
  .app-mockup.replay .anim-2,
  .app-mockup.replay .anim-3,
  .app-mockup.replay .anim-4 {
    animation: none;
  }
</style>

<script>
  const tabBtns = document.querySelectorAll<HTMLButtonElement>('.tab-btn');
  const tabPanels = document.querySelectorAll<HTMLElement>('.tab-panel');

  tabBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const target = btn.dataset.tab;

      // Update buttons
      tabBtns.forEach((b) => {
        const active = b.dataset.tab === target;
        b.setAttribute('aria-selected', String(active));
        b.classList.toggle('bg-accent', active);
        b.classList.toggle('text-white', active);
        b.classList.toggle('border-accent', active);
        b.classList.toggle('bg-white', !active);
        b.classList.toggle('text-gray-600', !active);
        b.classList.toggle('border-gray-200', !active);
      });

      // Update panels
      tabPanels.forEach((panel) => {
        panel.classList.toggle('hidden', !panel.id.includes(target!));
      });

      // Re-trigger mockup entrance animation
      const mockup = document.querySelector<HTMLElement>(`.app-mockup[data-mockup="${target}"]`);
      if (mockup) {
        mockup.classList.add('replay');
        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            mockup.classList.remove('replay');
          });
        });
      }
    });
  });
</script>
