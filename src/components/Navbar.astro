---
import type { Lang, Translations } from '../i18n/utils';

interface Props {
  lang: Lang;
  t: Translations;
}

const { lang, t } = Astro.props;
const base = import.meta.env.BASE_URL;

const langPaths: Record<Lang, string> = {
  en: base,
  de: `${base}de`,
  fr: `${base}fr`,
  es: `${base}es`,
};
---

<nav
  id="navbar"
  class="fixed top-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-sm border-b border-gray-100 transition-shadow duration-300"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 lg:h-18">
      <!-- Logo -->
      <a href={langPaths[lang]} class="flex items-center gap-2 shrink-0">
        <img src={`${base}logo-icon.png`} alt="Tenants10" class="h-9 w-9" />
        <img src={`${base}logo-text.png`} alt="Tenants10" class="h-6" />
      </a>

      <!-- Desktop Nav -->
      <div class="hidden lg:flex items-center gap-8">
        <a href="#features" class="text-sm font-medium text-gray-600 hover:text-primary transition-colors">
          {t.nav.features}
        </a>
        <a href="#how-it-works" class="text-sm font-medium text-gray-600 hover:text-primary transition-colors">
          {t.nav.howItWorks}
        </a>
        <a href="#who-we-help" class="text-sm font-medium text-gray-600 hover:text-primary transition-colors">
          {t.nav.whoWeHelp}
        </a>
        <a href="#faq" class="text-sm font-medium text-gray-600 hover:text-primary transition-colors">
          {t.nav.faq}
        </a>
      </div>

      <!-- Desktop Right -->
      <div class="hidden lg:flex items-center gap-4">
        <!-- Language switcher -->
        <div class="flex items-center gap-1 text-sm">
          {(['en', 'de', 'fr', 'es'] as Lang[]).map((l) => (
            <a
              href={langPaths[l]}
              class={`px-2 py-1 rounded font-medium transition-colors ${
                l === lang
                  ? 'text-primary font-semibold'
                  : 'text-gray-400 hover:text-gray-600'
              }`}
            >
              {l.toUpperCase()}
            </a>
          ))}
        </div>
        <a
          href="#get-started"
          class="bg-primary text-white px-5 py-2 rounded-full text-sm font-semibold hover:bg-primary-dark transition-colors"
        >
          {t.nav.bookDemo}
        </a>
      </div>

      <!-- Mobile: Book Demo + hamburger -->
      <div class="flex lg:hidden items-center gap-2">
        <a
          href="#get-started"
          class="bg-primary text-white px-4 py-2 rounded-full text-xs font-semibold hover:bg-primary-dark transition-colors"
        >
          {t.nav.bookDemo}
        </a>
        <button
          id="mobile-menu-btn"
          class="p-2 rounded-lg text-gray-600 hover:bg-gray-100 transition-colors"
          aria-label="Open menu"
        >
        <svg id="icon-open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
        <svg id="icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden lg:hidden border-t border-gray-100 bg-white">
    <div class="px-4 py-4 space-y-3">
      <a href="#features" class="block py-2 text-sm font-medium text-gray-700 hover:text-primary">
        {t.nav.features}
      </a>
      <a href="#how-it-works" class="block py-2 text-sm font-medium text-gray-700 hover:text-primary">
        {t.nav.howItWorks}
      </a>
      <a href="#who-we-help" class="block py-2 text-sm font-medium text-gray-700 hover:text-primary">
        {t.nav.whoWeHelp}
      </a>
      <a href="#faq" class="block py-2 text-sm font-medium text-gray-700 hover:text-primary">
        {t.nav.faq}
      </a>
      <!-- Language switcher mobile -->
      <div class="flex gap-3 pt-2 border-t border-gray-100">
        {(['en', 'de', 'fr', 'es'] as Lang[]).map((l) => (
          <a
            href={langPaths[l]}
            class={`text-sm font-medium px-2 py-1 rounded transition-colors ${
              l === lang ? 'text-primary font-bold' : 'text-gray-400 hover:text-gray-600'
            }`}
          >
            {l.toUpperCase()}
          </a>
        ))}
      </div>
      <a
        href="#get-started"
        class="block w-full text-center bg-primary text-white px-5 py-2.5 rounded-full text-sm font-semibold hover:bg-primary-dark transition-colors mt-2"
      >
        {t.nav.bookDemo}
      </a>
    </div>
  </div>
</nav>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden', isOpen);
    iconOpen?.classList.toggle('hidden', !isOpen);
    iconClose?.classList.toggle('hidden', isOpen);
  });

  // Close menu when a link is clicked
  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      menu.classList.add('hidden');
      iconOpen?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
    });
  });

  // Scroll shadow
  const navbar = document.getElementById('navbar');
  window.addEventListener('scroll', () => {
    navbar?.classList.toggle('shadow-md', window.scrollY > 10);
  });
</script>
